generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  createdAt    DateTime   @default(now())
  simulados    Simulado[]
}

model Simulado {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titulo        String?
  cargo         String?
  banca         String?
  totalQuestoes Int
  acertos       Int
  percentual    Int
  questoes      String
  respostas     String
  finalizadoEm  DateTime @default(now())

  @@index([userId])
}
